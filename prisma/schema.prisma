model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role
  status   String @default("active") // active | banned

  tutorProfile    TutorProfile?
  studentBookings Booking[]     @relation("StudentBookings")
  tutorBookings   Booking[]     @relation("TutorBookings")
  reviewsGiven    Review[]      @relation("StudentReviews")
  reviewsReceived Review[]      @relation("TutorReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@map("User")
  availabilities Availability[]
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

model TutorProfile {
  id          String   @id @default(uuid())
  bio         String?
  experience  Int?
  hourlyRate  Float?
  subjects    String[] // e.g. ["Math", "English"]
  avgRating   Float    @default(0)
  totalReview Int      @default(0)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  bookings Booking[]
}


enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Availability {
  id        String    @id @default(uuid())
  tutorId   String
  day       DayOfWeek 
  startTime String    // e.g., "10:00 AM"
  endTime   String    // e.g., "11:00 AM"

  tutor     User      @relation(fields: [tutorId], references: [id])
  @@index([tutorId])
  @@map("availabilities")
}

model Booking {
  id         String        @id @default(uuid())
  studentId  String
  tutorId    String
  categoryId String?
  date       DateTime
  time       String
  status     BookingStatus @default(CONFIRMED)

  student User @relation("StudentBookings", fields: [studentId], references: [id])
  tutor   User @relation("TutorBookings", fields: [tutorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())

  @@index([tutorId])
  @@index([studentId])
  @@index([date])
  @@map("Booking")
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  studentId String
  tutorId   String

  student User @relation("StudentReviews", fields: [studentId], references: [id])
  tutor   User @relation("TutorReviews", fields: [tutorId], references: [id])

  createdAt DateTime @default(now())
}